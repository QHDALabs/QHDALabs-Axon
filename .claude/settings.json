{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./.venv/Scripts/python.exe -m pytest:*)",
      "Bash(./.venv/Scripts/python.exe -m pip show:*)",
      "Bash(./.venv/Scripts/python.exe -c:*)",
      "Bash(./.venv/Scripts/python.exe examples/:*)",
      "Read(./**)"
    ],
    "deny": [
      "Edit(./Manifest.md)",
      "Write(./Manifest.md)"
    ]
  }
}
